# do not use both of these, you're trying things out
export CF_ACCESS_KEY_ID=`op read op://deploy/jamiecurle.com/CF_ACCESS_KEY_ID`
export CF_SECRET_ACCESS_KEY=`op read op://deploy/jamiecurle.com/CF_SECRET_ACCESS_KEY`
export CF_HOST=`op read op://deploy/jamiecurle.com/CF_HOST_DEV`
export CF_BUCKET=`op read op://deploy/jamiecurle.com/CF_BUCKET_DEV`
export CF_S3_HOST=`op read op://deploy/jamiecurle.com/CF_S3_HOST`
export LINKDING_API_TOKEN=`op read op://deploy/jamiecurle.com/LINKDING_API_TOKEN`
export LINKDING_HOST=`op read op://deploy/jamiecurle.com/LINKDING_HOST`

